module panic;

# Panic — hard abort, no unwinding
# Calls puts directly via primitive

void panic(string message) {
    puts(message);
}

void panic_oom() {
    panic("panic: out of memory");
}

void panic_bounds(int index, int length) {
    panic("panic: index out of bounds");
}

void panic_divide_zero() {
    panic("panic: division by zero");
}

void panic_stack_overflow() {
    panic("panic: stack overflow");
}

void panic_unwrap_none() {
    panic("panic: attempted to unwrap none");
}
